rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user owns their profile doc (Kaggle username/key/slugs) and their
    // activity subcollection. Only that user can read or write it — this is what
    // keeps one person's Kaggle key out of everyone else's reach.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /activity/{date} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Leaderboards are world-readable (so anyone can see the rankings) but only
    // the server (firebase-admin, which bypasses these rules) may write them.
    // Clients can never forge a score.
    match /leaderboards/{compId}/entries/{uid} {
      allow read: if true;
      allow write: if false;
    }
  }
}
