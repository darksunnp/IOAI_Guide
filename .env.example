# Copy to .env and fill in. The server reads these at startup.
# (Locally you can also just set them in your shell.)

# Port the Node server listens on.
PORT=3000

# Absolute path to your learning content. Defaults to ../AI_gold next to this
# project, which is correct for the local layout. Set explicitly on Nest.
# AI_GOLD_DIR=/home/darksun/AI_gold

# --- Firebase (enables login, Kaggle, activity, leaderboard) ----------------
# Path to the firebase-admin service-account JSON you downloaded from the
# Firebase console (Project settings → Service accounts → Generate new private
# key). Without this the server runs in content-only mode.
# FIREBASE_SERVICE_ACCOUNT=/home/darksun/secrets/ioai-firebase.json

# Comma-separated Firebase UIDs allowed into the admin pages / write endpoints.
# Find your UID after first sign-in on the Manage Content page (it's shown there)
# or in the Firebase console → Authentication → Users.
# ADMIN_UIDS=abc123uid,def456uid
